<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Gadiario" parent="Theme.Material3.Light">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Gadiario" parent="Base.Theme.Gadiario">
        <!-- Cor da Barra de Status aqui -->
        <item name="android:statusBarColor">@color/agro_primary_green</item>
        <item name="android:windowTranslucentStatus">false</item>

        <!-- Ícones brancos na barra de status (meu verde é escuro) -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Cores principais do tema -->
        <item name="colorPrimary">@color/agro_primary_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/agro_background_cream</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- 3. Forçar o verde na ActionBar -->
        <item name="actionBarStyle">@style/Widget.Gadiario.ActionBar</item>
    </style>

    <!-- Estilo customizado para a Barra -->
    <style name="Widget.Gadiario.ActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/agro_primary_green</item>
        <item name="titleTextStyle">@style/TextAppearance.Gadiario.ActionBar.Title</item>
    </style>

    <!-- Estilo do título dentro da barra para ficar branco -->
    <style name="TextAppearance.Gadiario.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
    </style>
</resources>